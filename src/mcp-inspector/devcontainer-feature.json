{
    "name": "MCP Inspector",
    "id": "mcp-inspector",
    "version": "1.0.2",
    "description": "Installs the Model Context Protocol (MCP) Inspector, the official tool for testing and debugging MCP servers.",
    "options": {
        "version": {
            "type": "string",
            "default": "latest",
            "description": "Version of @modelcontextprotocol/inspector to install"
        },
        "telemetry": {
            "type": "boolean",
            "default": true,
            "description": "Enable or disable telemetry during installation. See README.md for details."
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ],
    "customizations": {
        "vscode": {
            "settings": {},
            "extensions": []
        },
        "forwardPorts": [
            6274
        ]
    }
}
